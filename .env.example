# App
NODE_ENV=development
APP_NAME=ARGUS
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000
PUBLIC_EXAM_URL=http://localhost:3000/exam

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/argus_db

# Redis and durable BullMQ jobs
REDIS_URL=redis://127.0.0.1:6379
REDIS_REQUIRE_NOEVICTION=false
EXAM_REMINDER_MINUTES_BEFORE=30
ALLOW_EXAMINER_SELF_REGISTRATION=true

# JWT
JWT_ACCESS_SECRET=replace_with_at_least_32_character_access_secret
JWT_REFRESH_SECRET=replace_with_at_least_32_character_refresh_secret
JWT_ATTEMPT_SECRET=replace_with_at_least_32_character_attempt_secret
JWT_EXAM_ACCESS_SECRET=replace_with_at_least_32_character_exam_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ATTEMPT_EXPIRES_IN=4h
JWT_EXAM_ACCESS_EXPIRES_IN=10m
JWT_ISSUER=argus-api
JWT_AUDIENCE=argus-client

# Cookies and cross-site protection
REFRESH_COOKIE_NAME=argus_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_ENABLED=false

# Default Super Admin Seed
DEFAULT_ADMIN_EMAIL=admin@gmail.com
DEFAULT_ADMIN_PASSWORD=123456789

# Brevo
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_SENDER_EMAIL=your_verified_sender@example.com
BREVO_SENDER_NAME=ARGUS

# Email Behavior
SEND_EMAILS=true
EMAIL_TEMPLATE_BRAND_NAME=ARGUS
EMAIL_TEMPLATE_SUPPORT_EMAIL=support@argus.local

# Cloudinary private evidence and question assets
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret
CLOUDINARY_FOLDER=argus
EVIDENCE_SIGNED_URL_EXPIRES_SECONDS=300

# Security
BCRYPT_SALT_ROUNDS=12
ACCESS_CODE_HASH_SECRET=replace_with_private_access_code_hash_secret
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX_REQUESTS=5
PUBLIC_EXAM_RATE_LIMIT_MAX_REQUESTS=30

# Exam Access
EXAM_ACCESS_CODE_LENGTH=6
EXAM_SLUG_LENGTH=10

# Uploads
MAX_UPLOAD_SIZE_MB=5
UPLOAD_DIR=uploads

# Anti-Cheat Defaults
DEFAULT_MAX_TAB_SWITCHES=2
DEFAULT_MAX_FULLSCREEN_EXITS=2
DEFAULT_MAX_WINDOW_BLUR_EVENTS=2
DEFAULT_MAX_REFRESH_ATTEMPTS=2
DEFAULT_AUTO_SUBMIT_VIOLATION_SCORE=8
DEFAULT_WARNING_VIOLATION_SCORE=3
DEFAULT_FINAL_WARNING_VIOLATION_SCORE=5
DEFAULT_MAX_AWAY_SECONDS=10

# Logs
LOG_LEVEL=info
